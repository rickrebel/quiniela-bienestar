# Clave secreta de Django. Genera una nueva para producción.
SECRET_KEY=cambia-esta-clave-por-una-segura

# Modo depuración. Usa False en producción.
DEBUG=True

# Hosts permitidos, separados por comas.
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos PostgreSQL.
# Si POSTGRES_DB queda vacío, el proyecto usa SQLite por defecto.
POSTGRES_DB=quiniela-bienestar
POSTGRES_USER=quiniela_user
POSTGRES_PASSWORD=cambia-esta-contraseña
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Solo para el bootstrap del fork: nombre de la BD de la quiniela ORIGINAL
# desde la que se clona (mismas credenciales que arriba; solo cambia el
# nombre). La usa el paso `pg_dump | psql` documentado en el README; la app
# en runtime nunca lee esta variable.
POSTGRES_DB_ORIGINAL=quiniela-local

# Cuenta de Gmail para el envío de correos (contraseña de aplicación).
GMAIL_USER=tu_correo@gmail.com
GMAIL_APP_PASSWORD=contraseña-de-aplicacion-de-16-caracteres

# Token de football-data.org (se envía como header X-Auth-Token).
# Regístrate en https://www.football-data.org/ para obtenerlo. El free tier
# incluye la competición del Mundial (WC).
FOOTBALL_DATA_API_TOKEN=

# Servidor SMTP para el envío de correos (SSL).
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465
